# stripe-webhook — Environment Variables
#
# Built-in (auto-injected by Appwrite — do NOT create manually):
#   APPWRITE_FUNCTION_API_ENDPOINT — endpoint del proyecto
#   APPWRITE_FUNCTION_PROJECT_ID  — project ID
#   req.headers['x-appwrite-key'] — dynamic API key (runtime only)
#
# Project-level globals (configurar una vez, accesibles por todas las Functions):
APPWRITE_DATABASE_ID=omzone_db
APPWRITE_COLLECTION_ORDERS=orders
APPWRITE_COLLECTION_PAYMENTS=payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

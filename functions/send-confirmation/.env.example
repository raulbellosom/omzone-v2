# ── Built-in (auto-injected by Appwrite at runtime) ──
# APPWRITE_FUNCTION_API_ENDPOINT=
# APPWRITE_FUNCTION_PROJECT_ID=
# x-appwrite-key header (dynamic, not an env var)

# ── Project-level globals (set in Appwrite console → Settings → Global Variables) ──
# APPWRITE_DATABASE_ID=omzone_db
# APPWRITE_COLLECTION_ORDERS=orders
# APPWRITE_COLLECTION_ORDER_ITEMS=order_items
# APPWRITE_COLLECTION_TICKETS=tickets
# APPWRITE_COLLECTION_NOTIFICATION_TEMPLATES=notification_templates
# APPWRITE_COLLECTION_USER_PROFILES=user_profiles

# ── Email provider ──
# EMAIL_PROVIDER=resend          # resend | smtp
# EMAIL_FROM=OMZONE <noreply@omzone.com>

# Provider: Resend
# RESEND_API_KEY=re_xxxxxxxx

# Provider: SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

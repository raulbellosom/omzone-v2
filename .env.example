# ─── Site ───
VITE_SITE_URL=https://omzone.com

# ─── Appwrite Core ───
# These are NOT needed in Functions — Appwrite auto-injects:
#   APPWRITE_FUNCTION_API_ENDPOINT, APPWRITE_FUNCTION_PROJECT_ID,
#   x-appwrite-key header (dynamic API key at runtime)
APPWRITE_ENDPOINT=https://aprod.racoondevs.com/v1
APPWRITE_PROJECT_ID=omzone-dev
APPWRITE_API_KEY=

# ─── Database ───
# Set via: appwrite project create-variable --key <KEY> --value <VALUE>
# Available to ALL Appwrite Functions at runtime automatically.
APPWRITE_DATABASE_ID=omzone_db

# ─── Collection IDs ───
APPWRITE_COLLECTION_EXPERIENCES=experiences
APPWRITE_COLLECTION_EDITIONS=editions
APPWRITE_COLLECTION_PRICING_TIERS=pricing_tiers
APPWRITE_COLLECTION_PRICING_OPTIONS=pricing_rules
APPWRITE_COLLECTION_ADDONS=addons
APPWRITE_COLLECTION_ADDON_ASSIGNMENTS=addon_assignments
APPWRITE_COLLECTION_PACKAGES=packages
APPWRITE_COLLECTION_PACKAGE_ITEMS=package_items
APPWRITE_COLLECTION_PASSES=passes
APPWRITE_COLLECTION_USER_PASSES=user_passes
APPWRITE_COLLECTION_PASS_CONSUMPTIONS=pass_consumptions
APPWRITE_COLLECTION_SLOTS=slots
APPWRITE_COLLECTION_SLOT_RESOURCES=slot_resources
APPWRITE_COLLECTION_RESOURCES=resources
APPWRITE_COLLECTION_LOCATIONS=locations
APPWRITE_COLLECTION_ROOMS=rooms
APPWRITE_COLLECTION_ORDERS=orders
APPWRITE_COLLECTION_ORDER_ITEMS=order_items
APPWRITE_COLLECTION_PAYMENTS=payments
APPWRITE_COLLECTION_TICKETS=tickets
APPWRITE_COLLECTION_REFUNDS=refunds
APPWRITE_COLLECTION_PUBLICATIONS=publications
APPWRITE_COLLECTION_SECTIONS=sections
APPWRITE_COLLECTION_TAGS=tags
APPWRITE_COLLECTION_EXPERIENCE_TAGS=experience_tags
APPWRITE_COLLECTION_USER_PROFILES=user_profiles
APPWRITE_COLLECTION_SETTINGS=settings
APPWRITE_COLLECTION_BOOKINGS=bookings
APPWRITE_COLLECTION_NOTIFICATION_TEMPLATES=notification_templates
APPWRITE_COLLECTION_ADMIN_ACTIVITY_LOGS=admin_activity_logs
APPWRITE_COLLECTION_BOOKING_REQUESTS=booking_requests
APPWRITE_COLLECTION_TICKET_REDEMPTIONS=ticket_redemptions
APPWRITE_COLLECTION_CONTACT_MESSAGES=contact_messages

# ─── Bucket IDs ───
APPWRITE_BUCKET_EXPERIENCE_MEDIA=experience_media
APPWRITE_BUCKET_PUBLICATION_MEDIA=publication_media
APPWRITE_BUCKET_ADDON_IMAGES=addon_images
APPWRITE_BUCKET_PACKAGE_IMAGES=package_images
APPWRITE_BUCKET_USER_AVATARS=user_avatars
APPWRITE_BUCKET_DOCUMENTS=documents
APPWRITE_BUCKET_PUBLIC_RESOURCES=public-resources

# ─── Function IDs ───
APPWRITE_FUNCTION_CREATE_CHECKOUT=create-checkout
APPWRITE_FUNCTION_STRIPE_WEBHOOK=stripe-webhook
APPWRITE_FUNCTION_GENERATE_TICKET=generate-ticket
APPWRITE_FUNCTION_VALIDATE_TICKET=validate-ticket
APPWRITE_FUNCTION_CONSUME_PASS=consume-pass
APPWRITE_FUNCTION_ASSIGN_LABEL=assign-user-label
APPWRITE_FUNCTION_SEND_CONFIRMATION=send-confirmation
APPWRITE_FUNCTION_SEND_REMINDER=send-reminder

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email (send-confirmation) ───
EMAIL_PROVIDER=resend
EMAIL_FROM=OMZONE <noreply@omzone.com>
RESEND_API_KEY=re_...

# ─── Reminder config ───
REMINDER_WINDOW_START_HOURS=24
REMINDER_WINDOW_END_HOURS=48

# ─── Frontend ───
FRONTEND_URL=http://localhost:5173

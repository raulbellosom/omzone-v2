# ─── Appwrite Core (local dev / frontend only) ───
# These are NOT needed in Functions — Appwrite auto-injects:
#   APPWRITE_FUNCTION_API_ENDPOINT, APPWRITE_FUNCTION_PROJECT_ID,
#   x-appwrite-key header (dynamic API key at runtime)
APPWRITE_ENDPOINT=https://aprod.racoondevs.com/v1
APPWRITE_PROJECT_ID=omzone-dev
APPWRITE_API_KEY=test

# ─── Project-level Global Variables ───
# Set via: appwrite project create-variable --key <KEY> --value <VALUE>
# Available to ALL Appwrite Functions at runtime automatically.

APPWRITE_DATABASE_ID=omzone_db

# ─── Collection IDs ───
APPWRITE_COLLECTION_EXPERIENCES=
APPWRITE_COLLECTION_EDITIONS=
APPWRITE_COLLECTION_PRICING_TIERS=
APPWRITE_COLLECTION_PRICING_OPTIONS=
APPWRITE_COLLECTION_ADDONS=
APPWRITE_COLLECTION_ADDON_ASSIGNMENTS=
APPWRITE_COLLECTION_PACKAGES=
APPWRITE_COLLECTION_PACKAGE_ITEMS=
APPWRITE_COLLECTION_PASSES=
APPWRITE_COLLECTION_USER_PASSES=
APPWRITE_COLLECTION_PASS_CONSUMPTIONS=
APPWRITE_COLLECTION_SLOTS=
APPWRITE_COLLECTION_SLOT_RESOURCES=
APPWRITE_COLLECTION_RESOURCES=
APPWRITE_COLLECTION_LOCATIONS=
APPWRITE_COLLECTION_ROOMS=
APPWRITE_COLLECTION_ORDERS=
APPWRITE_COLLECTION_ORDER_ITEMS=
APPWRITE_COLLECTION_PAYMENTS=
APPWRITE_COLLECTION_TICKETS=
APPWRITE_COLLECTION_REFUNDS=
APPWRITE_COLLECTION_PUBLICATIONS=
APPWRITE_COLLECTION_SECTIONS=
APPWRITE_COLLECTION_TAGS=
APPWRITE_COLLECTION_EXPERIENCE_TAGS=
APPWRITE_COLLECTION_USER_PROFILES=
APPWRITE_COLLECTION_SETTINGS=

# ─── Bucket IDs ───
APPWRITE_BUCKET_EXPERIENCE_MEDIA=
APPWRITE_BUCKET_PUBLICATION_MEDIA=
APPWRITE_BUCKET_USER_AVATARS=
APPWRITE_BUCKET_DOCUMENTS=
APPWRITE_BUCKET_PUBLIC_RESOURCES=public-resources

# ─── Function IDs ───
APPWRITE_FUNCTION_CREATE_CHECKOUT=create-checkout
APPWRITE_FUNCTION_STRIPE_WEBHOOK=stripe-webhook
APPWRITE_FUNCTION_GENERATE_TICKET=generate-ticket
APPWRITE_FUNCTION_VALIDATE_TICKET=validate-ticket
APPWRITE_FUNCTION_CONSUME_PASS=consume-pass
APPWRITE_FUNCTION_ASSIGN_LABEL=assign-user-label

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Frontend ───
FRONTEND_URL=http://localhost:5173
